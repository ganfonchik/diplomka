<Page x:Class="Diplomka.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600"
      d:DesignWidth="800"
      Title="Settings">

    <Grid Background="#F4F6F9">

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="20">

                <!-- Заголовок -->
                <TextBlock Text="⚙ Настройки подключения"
                           FontSize="26"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>


                <!-- Основная карточка -->
                <materialDesign:Card Padding="25"
                                     Width="420"
                                     HorizontalAlignment="Left">

                    <StackPanel>

                        <!-- COM порт -->
                        <TextBlock Text="COM-порт"
                                   FontWeight="Bold"
                                   Margin="0,5"/>

                        <ComboBox x:Name="PortCombo"
                                  Height="35"
                                  Margin="0,5,0,15"/>


                        <!-- Baud rate -->
                        <TextBlock Text="Скорость (Baud Rate)"
                                   FontWeight="Bold"
                                   Margin="0,5"/>

                        <TextBox x:Name="BaudText"
                                 Text="9600"
                                 Height="35"
                                 Margin="0,5,0,15"/>


                        <!-- Симуляция -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,10">

                            <TextBlock Text="🧪 Режим симуляции"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>

                            <CheckBox x:Name="SimulateCheck"
                                      VerticalAlignment="Center"/>

                        </StackPanel>


                        <!-- Кнопки подключения -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,20,0,10">

                            <Button x:Name="ConnectBtn"
                                    Content="🔌 Подключить"
                                    Width="150"
                                    Height="40"
                                    Margin="5"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Click="ConnectBtn_Click"/>

                            <Button x:Name="DisconnectBtn"
                                    Content="❌ Отключить"
                                    Width="150"
                                    Height="40"
                                    Margin="5"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Click="DisconnectBtn_Click"/>

                        </StackPanel>


                        <!-- Кнопки управления -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,5">

                            <Button x:Name="SaveBtn"
                                    Content="💾 Сохранить"
                                    Width="150"
                                    Height="40"
                                    Margin="5"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Click="SaveBtn_Click"/>

                            <Button x:Name="ClearBtn"
                                    Content="🗑 Очистить логи"
                                    Width="150"
                                    Height="40"
                                    Margin="5"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Click="ClearBtn_Click"/>

                        </StackPanel>


                        <!-- Статус -->
                        <Border Background="#EEEEEE"
                                CornerRadius="5"
                                Padding="10"
                                Margin="0,25,0,0">

                            <TextBlock x:Name="StatusText"
                                       Text="Статус: не подключено"
                                       FontWeight="Bold"
                                       Foreground="#555"
                                       HorizontalAlignment="Center"/>

                        </Border>

                    </StackPanel>

                </materialDesign:Card>
                <!-- Панель версии -->
                <TextBlock Text="SensorHub v1.0"
                           Margin="0,20,0,0"
                           Foreground="Gray"
                           FontSize="12"/>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</Page>