<Window x:Class="Diplomka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Система сбора данных"
        Height="550"
        Width="1000"
        Background="#F4F6F9">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <StackPanel Grid.Column="0"
                    Background="#263238"
                    Margin="0">

            <TextBlock Text="SENSOR HUB"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="10"/>

            <Separator Margin="5"/>

            <Button Content="Главная"
                    Margin="5"
                    Click="Button_Click_1"/>

            <Button Content="Настройки"
                    Margin="5"
                    Click="Button_Click"/>

            <Button Content="Логи"
                    Margin="5"
                    Click="Button_Click_2"/>

        </StackPanel>

        <!-- Основная область -->
        <Grid Grid.Column="1" Margin="20" x:Name="MainContentGrid">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Карточки датчиков -->
            <WrapPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,15">

                <Border BorderBrush="Gray" BorderThickness="1" Margin="10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Температура" FontWeight="Bold"/>
                        <TextBlock x:Name="TempCard"
                                   Text="0 °C"
                                   FontSize="24"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="Gray" BorderThickness="1" Margin="10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Влажность" FontWeight="Bold"/>
                        <TextBlock x:Name="HumidityCard"
                                   Text="0 %"
                                   FontSize="24"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="Gray" BorderThickness="1" Margin="10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="CO2 / Свет" FontWeight="Bold"/>
                        <TextBlock x:Name="Co2Card"
                                   Text="0"
                                   FontSize="24"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

            </WrapPanel>

            <!-- График / Таблица -->
            <Grid Grid.Row="1">

                <Frame x:Name="ContentFrame"
                       NavigationUIVisibility="Hidden"/>

                <DataGrid x:Name="SensorTable"
                          Visibility="Collapsed"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          Background="White"/>

            </Grid>

        </Grid>

    </Grid>

</Window>