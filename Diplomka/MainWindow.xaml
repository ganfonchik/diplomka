<Window x:Class="Diplomka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Система сбора данных"
        Height="600"
        Width="1000"
        Background="#F4F6F9">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <StackPanel Grid.Column="0"
                    Background="#263238">

            <TextBlock Text="SENSOR HUB"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="15"/>

            <Separator Margin="5"/>

            <Button Content="🏠 Главная"
                    Margin="10"
                    Height="40"
                    Click="Button_Click_1"/>

            <Button Content="⚙ Настройки"
                    Margin="10"
                    Height="40"
                    Click="Button_Click"/>

            <Button Content="📜 Логи"
                    Margin="10"
                    Height="40"
                    Click="Button_Click_2"/>

        </StackPanel>

        <!-- Правая часть -->
        <Grid Grid.Column="1">

            <!-- DASHBOARD -->
            <Grid x:Name="DashboardPanel" Margin="20">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Карточки -->
                <UniformGrid Columns="3">

                    <Border Background="White"
                            Margin="10"
                            Padding="15"
                            CornerRadius="8">

                        <StackPanel>
                            <TextBlock Text="🌡 Температура"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="TempCard"
                                       Text="0 °C"
                                       FontSize="28"
                                       FontWeight="Bold"/>
                        </StackPanel>

                    </Border>

                    <Border Background="White"
                            Margin="10"
                            Padding="15"
                            CornerRadius="8">

                        <StackPanel>
                            <TextBlock Text="💧 Влажность"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="HumidityCard"
                                       Text="0 %"
                                       FontSize="28"
                                       FontWeight="Bold"/>
                        </StackPanel>

                    </Border>

                    <Border Background="White"
                            Margin="10"
                            Padding="15"
                            CornerRadius="8">

                        <StackPanel>
                            <TextBlock Text="💡 Свет"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="Co2Card"
                                       Text="0"
                                       FontSize="28"
                                       FontWeight="Bold"/>
                        </StackPanel>

                    </Border>

                </UniformGrid>

                <!-- предупреждение -->
                <Border Grid.Row="1"
                        Margin="10"
                        Padding="10"
                        Background="#FFF3CD"
                        BorderBrush="#FFC107"
                        BorderThickness="1"
                        CornerRadius="5">

                    <TextBlock x:Name="WarningText"
                               Text="✅ Система работает нормально"
                               FontWeight="Bold"/>

                </Border>

                <!-- график -->
                <Border Grid.Row="2"
                        Background="White"
                        Margin="10"
                        Padding="10"
                        CornerRadius="8">

                    <StackPanel>

                        <TextBlock Text="📈 График датчиков"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <Grid Height="300">

                            <Frame x:Name="ContentFrame"
                                   NavigationUIVisibility="Hidden"/>

                            <DataGrid x:Name="SensorTable"
                                      Visibility="Collapsed"
                                      AutoGenerateColumns="True"
                                      IsReadOnly="True"/>

                        </Grid>

                    </StackPanel>

                </Border>

            </Grid>


            <!-- СТРАНИЦА НАСТРОЕК -->
            <Frame x:Name="PageFrame"
                   Visibility="Collapsed"/>

        </Grid>

    </Grid>

</Window>