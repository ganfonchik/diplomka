<Window x:Class="Diplomka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Система сбора данных"
        Height="550"
        Width="1000"
        Background="#F4F6F9">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <StackPanel Grid.Column="0"
                    Background="#263238"
                    Margin="0">

            <TextBlock Text="SENSOR HUB"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="10"/>

            <Separator Margin="5"/>

            <Button Content="🏠 Главная"
        Margin="5"
        Height="40"
        Click="Button_Click_1"/>

            <Button Content="⚙ Настройки"
        Margin="5"
        Height="40"
        Click="Button_Click"/>

            <Button Content="📜 Логи"
        Margin="5"
        Height="40"
        Click="Button_Click_2"/>

        </StackPanel>

        <!-- Основная область -->
        <Grid Grid.Column="1" Margin="20" x:Name="MainContentGrid">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Карточки датчиков -->
            <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,15">

                <Border Background="White"
            CornerRadius="8"
            Margin="10"
            Padding="15"
            BorderBrush="#E0E0E0"
            BorderThickness="1">

                    <StackPanel>
                        <TextBlock Text="🌡 Температура"
                       FontWeight="Bold"
                       FontSize="14"
                       Foreground="#555"/>

                        <TextBlock x:Name="TempCard"
                       Text="0 °C"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,5,0,0"/>
                    </StackPanel>

                </Border>

                <Border Background="White"
            CornerRadius="8"
            Margin="10"
            Padding="15"
            BorderBrush="#E0E0E0"
            BorderThickness="1">

                    <StackPanel>
                        <TextBlock Text="💧 Влажность"
                       FontWeight="Bold"
                       FontSize="14"
                       Foreground="#555"/>

                        <TextBlock x:Name="HumidityCard"
                       Text="0 %"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,5,0,0"/>
                    </StackPanel>

                </Border>

                <Border Background="White"
            CornerRadius="8"
            Margin="10"
            Padding="15"
            BorderBrush="#E0E0E0"
            BorderThickness="1">

                    <StackPanel>
                        <TextBlock Text="💡 Свет"
                       FontWeight="Bold"
                       FontSize="14"
                       Foreground="#555"/>

                        <TextBlock x:Name="Co2Card"
                       Text="0"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,5,0,0"/>
                    </StackPanel>

                </Border>

            </UniformGrid>

            <Border Grid.Row="0"
        Margin="10,110,10,0"
        Padding="10"
        Background="#FFF3CD"
        BorderBrush="#FFC107"
        BorderThickness="1"
        CornerRadius="5">

                <TextBlock x:Name="WarningText"
               Text="✅ Система работает нормально"
               FontSize="14"
               FontWeight="Bold"
               Foreground="#856404"/>
            </Border>

            <!-- График / Таблица -->
            <Grid Grid.Row="1">

                <Frame x:Name="ContentFrame"
                       NavigationUIVisibility="Hidden"/>

                <DataGrid x:Name="SensorTable"
                          Visibility="Collapsed"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          Background="White"/>

            </Grid>

        </Grid>

    </Grid>

</Window>