<Window x:Class="Diplomka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Система мониторинга датчиков"
        Height="850"
        Width="1100"
        Background="#F4F6F9">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <materialDesign:ColorZone Mode="PrimaryDark" Padding="10">

            <DockPanel>

                <TextBlock Text="📡 Система мониторинга датчиков"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right">

                    <materialDesign:PackIcon Kind="LanConnect"
                                             Width="24"
                                             Height="24"
                                             Margin="10"/>

                    <TextBlock Text="Arduino connection"
                               VerticalAlignment="Center"/>

                </StackPanel>

            </DockPanel>

        </materialDesign:ColorZone>


        <!-- Основная область -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Боковое меню -->
            <StackPanel Grid.Column="0"
                        Background="#263238">

                <TextBlock Text="SENSOR HUB"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="15"/>

                <Separator Margin="5"/>

                <Button Content="🏠 Главная"
                        Margin="10"
                        Height="40"
                        Click="Button_Click_1"/>

                <Button Content="⚙ Настройки"
                        Margin="10"
                        Height="40"
                        Click="Button_Click"/>

                <Button Content="📜 Логи"
                        Margin="10"
                        Height="40"
                        Click="Button_Click_2"/>

            </StackPanel>


            <!-- Центральная часть -->
            <ScrollViewer Grid.Column="1">

                <StackPanel Margin="20" x:Name="MainContentGrid">

                    <!-- Карточки датчиков -->
                    <UniformGrid Columns="3">

                        <materialDesign:Card Margin="10" Padding="15">
                            <StackPanel>
                                <TextBlock Text="🌡 Температура" FontWeight="Bold"/>
                                <TextBlock x:Name="TempCard"
                                           Text="0 °C"
                                           FontSize="32"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Margin="10" Padding="15">
                            <StackPanel>
                                <TextBlock Text="💧 Влажность" FontWeight="Bold"/>
                                <TextBlock x:Name="HumidityCard"
                                           Text="0 %"
                                           FontSize="32"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Margin="10" Padding="15">
                            <StackPanel>
                                <TextBlock Text="💡 Освещенность" FontWeight="Bold"/>
                                <TextBlock x:Name="Co2Card"
                                           Text="0"
                                           FontSize="32"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </materialDesign:Card>

                    </UniformGrid>


                    <!-- Панель предупреждения -->
                    <materialDesign:Card Margin="10" Padding="12">

                        <TextBlock x:Name="WarningText"
                                   Text="✅ Система работает нормально"
                                   FontWeight="Bold"
                                   FontSize="14"/>

                    </materialDesign:Card>


                    <!-- Блок статистики -->
                    <materialDesign:Card Margin="10" Padding="10">

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                            <TextBlock Text="📊 Сегодня записей: 0"
                                       Margin="20"/>

                            <TextBlock Text="🌡 Средняя температура: —"
                                       Margin="20"/>

                            <TextBlock Text="⚠ Предупреждений: 0"
                                       Margin="20"/>

                        </StackPanel>

                    </materialDesign:Card>


                    <!-- График -->
                    <materialDesign:Card Margin="10" Padding="15">

                        <StackPanel>

                            <TextBlock Text="📈 График датчиков"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <Grid Height="300">

                                <Frame x:Name="ContentFrame"
                                       NavigationUIVisibility="Hidden"/>

                                <DataGrid x:Name="SensorTable"
                                          Visibility="Collapsed"
                                          AutoGenerateColumns="True"
                                          IsReadOnly="True"
                                          Background="White"/>

                            </Grid>

                        </StackPanel>

                    </materialDesign:Card>

                </StackPanel>

            </ScrollViewer>

        </Grid>

    </Grid>

</Window>