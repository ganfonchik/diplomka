<Window x:Class="Diplomka.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Логи датчиков"
        Height="550"
        Width="950"
        Background="#F4F6F9">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- Панель фильтров -->
        <materialDesign:Card Padding="15" Margin="0,0,0,10">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <TextBox x:Name="SearchBox"
                         Grid.Column="0"
                         Height="35"
                         Margin="5"
                         materialDesign:HintAssist.Hint="Поиск по данным"/>

                <!-- Дата от -->
                <DatePicker x:Name="DateFrom"
                            Grid.Column="1"
                            Margin="5"/>

                <!-- Дата до -->
                <DatePicker x:Name="DateTo"
                            Grid.Column="2"
                            Margin="5"/>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal"
                            Grid.Column="3"
                            HorizontalAlignment="Right">

                    <Button Content="Фильтр"
                            Width="100"
                            Margin="5"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Click="Filter_Click"/>

                    <Button Content="Очистить"
                            Width="100"
                            Margin="5"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Click="Clear_Click"/>

                </StackPanel>

            </Grid>

        </materialDesign:Card>


        <!-- Панель статистики -->
        <materialDesign:Card Grid.Row="1"
                             Padding="10"
                             Margin="0,0,0,10">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <TextBlock Text="📄 Всего записей: 0"
                           Margin="20"/>

                <TextBlock Text="🌡 Средняя температура: —"
                           Margin="20"/>

                <TextBlock Text="💧 Средняя влажность: —"
                           Margin="20"/>

                <Button Content="Экспорт CSV"
                        Width="120"
                        Margin="20"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>

            </StackPanel>

        </materialDesign:Card>


        <!-- Таблица логов -->
        <DataGrid x:Name="LogsGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  Background="White"
                  materialDesign:DataGridAssist.CellPadding="8"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="8">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Дата"
                                    Binding="{Binding Timestamp}"
                                    SortMemberPath="Timestamp"
                                    Width="200"/>

                <DataGridTextColumn Header="Температура"
                                    Binding="{Binding Temp}"
                                    Width="*"/>

                <DataGridTextColumn Header="Влажность"
                                    Binding="{Binding Humidity}"
                                    Width="*"/>

                <DataGridTextColumn Header="Свет"
                                    Binding="{Binding Light}"
                                    Width="*"/>

                <DataGridTextColumn Header="CO₂"
                                    Binding="{Binding Co2}"
                                    Width="*"/>

                <DataGridTextColumn Header="Вода"
                                    Binding="{Binding Water}"
                                    Width="*"/>

                <DataGridTextColumn Header="Звук"
                                    Binding="{Binding Sound}"
                                    Width="*"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>